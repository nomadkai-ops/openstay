# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com)
# 1. Create account at resend.com
# 2. Add and verify your domain (DNS TXT + MX records)
# 3. Create an API key
RESEND_API_KEY=re_your-resend-key
# Format: "Name <email@yourdomain.com>" — must use your verified Resend domain
RESEND_FROM_EMAIL=OpenStay <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# App URL — used in email CTA buttons and Supabase auth redirects
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
